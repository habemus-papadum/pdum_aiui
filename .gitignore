# Dependencies
node_modules/

# Build output
dist/
*.tsbuildinfo

# Generated documentation (docs:gen output + VitePress artifacts). Rebuilt by `pnpm docs:gen`.
docs/packages/
docs/.vitepress/sidebar.generated.json
docs/.vitepress/cache/
docs/.vitepress/dist/

# Test / coverage
coverage/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Editor / OS
.DS_Store
*.local

# Local env
.env
.env.*
!.env.example

# Throwaway npmrc written by CI at publish time
.npmrc-publish

# aiui project-local cache (lowering traces, screenshots, Chrome profiles for the
# DevTools MCP — see docs/guide/web-intent-tool and docs/guide/getting-started)
.aiui-cache/

# aiui-devtools-extension build output (tsc)
packages/aiui-devtools-extension/extension/js/

# Other developers' agent worktrees (each is its own checkout)
.claude/worktrees/

# Pack-time skill-doc bundles (scripts/bundle-skill-docs.mjs): generated by the
# plugin package's prepack, removed by postpack — never committed.
packages/aiui-claude-plugin/marketplace/plugins/*/skills/*/references/
packages/aiui-claude-plugin/.skill-bundle-backup/
