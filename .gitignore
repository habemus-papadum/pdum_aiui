# Dependencies
node_modules/

# Build output
dist/
*.tsbuildinfo

# The CRXJS dev artifact (aiui-webext's webextConfig): loader stubs that only
# work while the extension's Vite dev server is running. Deliberately NOT dist/
# — a `pnpm build` must never be able to clobber a live dev install.
dist-dev/

# The intent client's MV3 bundle (`pnpm -C packages/aiui-intent-client build:ext`).
# Its own directory because it is a THIRD shape of the same package: dist/ is the
# library, dist-ext/ is the unpacked extension you load at chrome://extensions.
dist-ext/

# Generated documentation (docs:gen output + VitePress artifacts). Rebuilt by `pnpm docs:gen`.
docs/packages/
docs/.vitepress/sidebar.generated.json
docs/.vitepress/cache/
docs/.vitepress/dist/

# Test / coverage
coverage/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Editor / OS
.DS_Store
*.local

# Local env
.env
.env.*
!.env.example

# Throwaway npmrc written by CI at publish time
.npmrc-publish

# aiui project-local cache (lowering traces, screenshots, Chrome profiles for the
# DevTools MCP — see docs/guide/web-intent-tool and docs/guide/getting-started)
.aiui-cache/

# Transient local scratch demo: kept out of the repo on purpose (see the
# matching `!demos/circle` exclusion in pnpm-workspace.yaml). Its worthwhile
# parts live on as the gallery's `circle` notebook page.
demos/circle/

# aiui-devtools-extension build output (tsc)
packages/aiui-devtools-extension/extension/js/

# Other developers' agent worktrees (each is its own checkout)
.claude/worktrees/

# Pack-time skill-doc bundles (scripts/bundle-skill-docs.mjs): generated by the
# plugin package's prepack, removed by postpack — never committed.
packages/aiui-claude-plugin/marketplace/plugins/*/skills/*/references/
packages/aiui-claude-plugin/.skill-bundle-backup/
