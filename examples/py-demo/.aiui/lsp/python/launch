#!/usr/bin/env bash
# aiui LSP launcher — python (pyright). Generated by `aiui setup-lsp`.
# Speaks LSP on stdio; the channel/reader spawns this and pipes bytes.
# Portable: ROOT is this project (the launcher lives at .aiui/lsp/<lang>/launch,
# three levels down); the server resolves from the project's own node_modules
# and node comes from PATH — no absolute machine paths.
ROOT="$(cd "$(dirname "$0")/../../.." && pwd)"
exec "$ROOT/node_modules/.bin/pyright-langserver" --stdio "$@"
