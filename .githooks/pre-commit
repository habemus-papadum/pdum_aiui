#!/bin/sh
# Biome gate — CI runs `biome check .` and fails the build on any lint/format
# error, so catch it here first. `--staged` checks exactly what this commit
# ships; fixable errors: run `pnpm format` (repo-wide `biome check --write`)
# and re-stage. Bypass for a genuine emergency: `git commit --no-verify`.
pnpm exec biome check --staged --no-errors-on-unmatched || {
  echo ""
  echo "✖ biome found problems in the staged files."
  echo "  Fix: pnpm format   (then re-stage)   ·   bypass: git commit --no-verify"
  exit 1
}

# Docs gate — Biome can't lint markdown, so a bare `<path>` placeholder in prose
# sails through and only blows up the ~1-minute VitePress build on push (Vue: "Element
# is missing end tag"). This sub-second check catches that class up front. Whole-tree
# scan (it's fast, and main should never carry a broken doc); bypass with --no-verify.
node scripts/docs-lint.mjs || {
  echo ""
  echo "  Wrap literal placeholders in \`backticks\`   ·   bypass: git commit --no-verify"
  exit 1
}
