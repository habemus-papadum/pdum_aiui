{
  "name": "@habemus-papadum/aiui-webext",
  "version": "0.4.0+dev",
  "description": "Shared infrastructure for building aiui Chrome extensions: CRXJS/Vite config factory, manifest helpers, runtime message relay, side-panel pane primitives, in-page indicator, offscreen-document guard.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/habemus-papadum/pdum_aiui.git",
    "directory": "packages/aiui-webext"
  },
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./vite": "./src/vite.ts"
  },
  "imports": {
    "#dev-stamp": "./src/dev-stamp.ts"
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "restricted",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./vite": {
        "types": "./dist/vite.d.ts",
        "import": "./dist/vite.js",
        "default": "./dist/vite.js"
      }
    },
    "imports": {
      "#dev-stamp": "./dist/dev-stamp.js"
    }
  },
  "scripts": {
    "build": "tsc --emitDeclarationOnly -p tsconfig.json && vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@crxjs/vite-plugin": "^2.7.1",
    "vite-plugin-solid": "3.0.0-next.5"
  },
  "peerDependencies": {
    "@solidjs/web": ">=2.0.0-beta.0 <2.0.0-experimental.0",
    "solid-js": ">=2.0.0-beta.0 <2.0.0-experimental.0",
    "vite": ">=6"
  },
  "peerDependenciesMeta": {
    "@solidjs/web": {
      "optional": true
    },
    "solid-js": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@solidjs/web": "2.0.0-beta.15",
    "@types/chrome": "^0.0.287",
    "solid-js": "2.0.0-beta.15",
    "vite": "^6.4.1"
  }
}
