{
  "name": "@habemus-papadum/aiui-paint",
  "version": "0.2.0+dev",
  "description": "iPad-to-browser remote paint stream: wire protocol, LAN relay, browser host controller, and iPad client.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/habemus-papadum/pdum_aiui.git",
    "directory": "packages/aiui-paint"
  },
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./relay": "./src/relay.ts"
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "aiui-paint": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./relay": {
        "types": "./dist/relay.d.ts",
        "import": "./dist/relay.js"
      }
    }
  },
  "scripts": {
    "build": "tsc --emitDeclarationOnly -p tsconfig.json && vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@habemus-papadum/aiui-claude-channel": "workspace:^",
    "@habemus-papadum/aiui-ink": "workspace:^",
    "commander": "^15.0.0",
    "express": "^5.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/ws": "^8.5.0"
  }
}
