{
  "name": "@habemus-papadum/aiui-intent-client",
  "version": "0.6.0+dev",
  "description": "The greenfield intent client: a detached plain-page panel on the mode engine \u2014 agent-drivable, HMR-native; the MV3 extension is a shell added last.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/habemus-papadum/pdum_aiui.git",
    "directory": "packages/aiui-intent-client"
  },
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./sidecar": "./src/sidecar.ts"
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "dist",
    "dist-ext",
    "assets"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./sidecar": {
        "types": "./dist/sidecar.d.ts",
        "import": "./dist/sidecar.js",
        "default": "./dist/sidecar.js"
      }
    }
  },
  "scripts": {
    "build": "tsc --emitDeclarationOnly -p tsconfig.json && vite build && pnpm build:panel && pnpm build:ext",
    "build:panel": "vite build --config vite.panel.config.ts",
    "build:ext": "tsx scripts/build-ext.ts",
    "ext:watch": "tsx scripts/build-ext.ts --watch",
    "load:ext": "tsx scripts/load-ext.ts",
    "ext": "pnpm build:ext && pnpm load:ext",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "dev": "tsx scripts/dev.ts",
    "dev:plain": "vite"
  },
  "dependencies": {
    "@habemus-papadum/aiui-intent-runtime": "workspace:^",
    "@habemus-papadum/aiui-lowering-pipeline": "workspace:^",
    "@habemus-papadum/aiui-pencil": "workspace:^",
    "@habemus-papadum/aiui-remote-bar": "workspace:^",
    "@habemus-papadum/aiui-trace-ui": "workspace:^",
    "@habemus-papadum/aiui-util": "workspace:^",
    "@habemus-papadum/aiui-viz": "workspace:^",
    "@solidjs/web": "2.0.0-beta.15",
    "solid-js": "2.0.0-beta.15",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@habemus-papadum/aiui-build-config": "workspace:^",
    "@habemus-papadum/aiui-claude-channel": "workspace:^",
    "@habemus-papadum/aiui-vscode": "workspace:^",
    "@types/chrome": "^0.0.287",
    "@types/express": "^5.0.0",
    "@types/ws": "^8.5.0",
    "esbuild": "^0.25.12",
    "express": "^5.1.0",
    "jsdom": "^25.0.1",
    "tsx": "^4.22.5",
    "vite": "^6.4.1",
    "vite-plugin-solid": "3.0.0-next.5"
  }
}
