{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "declarationDir": "dist",
    // Solid-capable (see proposals/solid-rewrite.md): new components are Solid
    // `.tsx`; the existing vanilla `.ts` surface has no JSX and is unaffected.
    "jsx": "preserve",
    "jsxImportSource": "@solidjs/web"
  },
  "include": ["src"],
  "exclude": ["dist", "node_modules", "src/**/*.test.ts", "src/test-support"]
}
