{
  "name": "@habemus-papadum/aiui-dev-overlay",
  "version": "0.4.0+dev",
  "description": "Browser-side dev overlay: a Shadow-DOM floating tool surface you import and mount.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/habemus-papadum/pdum_aiui.git",
    "directory": "packages/aiui-dev-overlay"
  },
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./vite": "./src/vite.ts",
    "./intent-pipeline": "./src/intent-pipeline/index.ts",
    "./debug-ui": "./src/debug-ui/index.ts",
    "./protocol": "./src/protocol.ts",
    "./selection": "./src/selection.ts",
    "./intent-thread": "./src/intent-thread.ts",
    "./wire": "./src/multimodal/shell/wire.ts"
  },
  "imports": {
    "#source-locator": "./src/source-locator.ts"
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./vite": {
        "types": "./dist/vite.d.ts",
        "import": "./dist/vite.js",
        "default": "./dist/vite.js"
      },
      "./intent-pipeline": {
        "types": "./dist/intent-pipeline/index.d.ts",
        "import": "./dist/intent-pipeline.js",
        "default": "./dist/intent-pipeline.js"
      },
      "./debug-ui": {
        "types": "./dist/debug-ui/index.d.ts",
        "import": "./dist/debug-ui.js",
        "default": "./dist/debug-ui.js"
      },
      "./protocol": {
        "types": "./dist/protocol.d.ts",
        "import": "./dist/protocol.js",
        "default": "./dist/protocol.js"
      },
      "./selection": {
        "types": "./dist/selection.d.ts",
        "import": "./dist/selection.js",
        "default": "./dist/selection.js"
      },
      "./intent-thread": {
        "types": "./dist/intent-thread.d.ts",
        "import": "./dist/intent-thread.js",
        "default": "./dist/intent-thread.js"
      },
      "./wire": {
        "types": "./dist/multimodal/shell/wire.d.ts",
        "import": "./dist/multimodal/shell/wire.js",
        "default": "./dist/multimodal/shell/wire.js"
      }
    },
    "imports": {
      "#source-locator": "./dist/source-locator.js"
    }
  },
  "scripts": {
    "build": "tsc --emitDeclarationOnly -p tsconfig.json && vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@babel/core": "^7.29.0",
    "@solidjs/web": ">=2.0.0-beta.0 <2.0.0-experimental.0",
    "solid-js": ">=2.0.0-beta.0 <2.0.0-experimental.0",
    "vite": ">=6"
  },
  "peerDependenciesMeta": {
    "@babel/core": {
      "optional": true
    },
    "@solidjs/web": {
      "optional": true
    },
    "solid-js": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  },
  "dependencies": {
    "@habemus-papadum/aiui-paint": "workspace:^",
    "@habemus-papadum/aiui-viz": "workspace:^"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@habemus-papadum/aiui-claude-channel": "workspace:^",
    "@solidjs/web": "2.0.0-beta.15",
    "@types/babel__core": "^7.20.5",
    "jsdom": "^29.0.0",
    "monaco-editor": "^0.55.0",
    "solid-js": "2.0.0-beta.15",
    "vite": "^6.4.1",
    "vite-plugin-solid": "3.0.0-next.5"
  }
}
