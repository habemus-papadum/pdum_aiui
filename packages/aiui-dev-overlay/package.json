{
  "name": "@habemus-papadum/aiui-dev-overlay",
  "version": "0.0.0+dev",
  "description": "Browser-side dev overlay: a Shadow-DOM floating tool surface you import and mount.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/habemus-papadum/pdum_aiui.git",
    "directory": "packages/aiui-dev-overlay"
  },
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./vite": "./src/vite.ts"
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./vite": {
        "types": "./dist/vite.d.ts",
        "import": "./dist/vite.js"
      }
    }
  },
  "scripts": {
    "build": "tsc --emitDeclarationOnly -p tsconfig.json && vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "peerDependencies": {
    "vite": ">=6"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@habemus-papadum/aiui-claude-channel": "workspace:^",
    "jsdom": "^29.0.0",
    "vite": "^6.4.1"
  }
}
