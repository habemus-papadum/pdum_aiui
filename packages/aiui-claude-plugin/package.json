{
  "name": "@habemus-papadum/aiui-claude-plugin",
  "version": "0.2.0+dev",
  "description": "A Claude plugin (skills, commands, scripts) with a CLI for configuration info.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/habemus-papadum/pdum_aiui.git",
    "directory": "packages/aiui-claude-plugin"
  },
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts"
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "aiui-claude-plugin": "./dist/cli.js"
  },
  "files": [
    "dist",
    "marketplace"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsc --emitDeclarationOnly -p tsconfig.json && vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "prepack": "node ../../scripts/bundle-skill-docs.mjs pack",
    "postpack": "node ../../scripts/bundle-skill-docs.mjs restore"
  },
  "dependencies": {
    "commander": "^15.0.0"
  }
}
