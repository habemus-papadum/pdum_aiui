{
  "name": "@habemus-papadum/aiui-viz",
  "version": "0.12.0+dev",
  "description": "Reactive scientific-visualization utilities for agent-written frontends: Observable-style async cells for SolidJS 2.0, worker streaming, durable HMR registries, and the agent tool surface.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/habemus-papadum/pdum_aiui.git",
    "directory": "packages/aiui-viz"
  },
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./plot": "./src/plot.tsx",
    "./mosaic": "./src/mosaic.tsx",
    "./duckdb": "./src/duckdb.ts",
    "./site": "./src/site/index.ts",
    "./modal": "./src/modal/index.ts",
    "./testing": "./src/testing.ts"
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./plot": {
        "types": "./dist/plot.d.ts",
        "import": "./dist/plot.js",
        "default": "./dist/plot.js"
      },
      "./mosaic": {
        "types": "./dist/mosaic.d.ts",
        "import": "./dist/mosaic.js",
        "default": "./dist/mosaic.js"
      },
      "./duckdb": {
        "types": "./dist/duckdb.d.ts",
        "import": "./dist/duckdb.js",
        "default": "./dist/duckdb.js"
      },
      "./site": {
        "types": "./dist/site/index.d.ts",
        "import": "./dist/site.js",
        "default": "./dist/site.js"
      },
      "./modal": {
        "types": "./dist/modal/index.d.ts",
        "import": "./dist/modal.js",
        "default": "./dist/modal.js"
      },
      "./testing": {
        "types": "./dist/testing.d.ts",
        "import": "./dist/testing.js",
        "default": "./dist/testing.js"
      }
    }
  },
  "scripts": {
    "build": "tsc --emitDeclarationOnly -p tsconfig.json && vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@duckdb/duckdb-wasm": ">=1.29",
    "@observablehq/plot": "^0.6",
    "@solidjs/web": ">=2.0.0-beta.0 <2.0.0-experimental.0",
    "@uwdata/mosaic-plot": ">=0.28",
    "solid-js": ">=2.0.0-beta.0 <2.0.0-experimental.0",
    "katex": "^0.16 || ^0.17"
  },
  "peerDependenciesMeta": {
    "@duckdb/duckdb-wasm": {
      "optional": true
    },
    "@observablehq/plot": {
      "optional": true
    },
    "@uwdata/mosaic-plot": {
      "optional": true
    },
    "katex": {
      "optional": true
    }
  },
  "devDependencies": {
    "@duckdb/duckdb-wasm": "1.33.1-dev45.0",
    "@habemus-papadum/aiui-build-config": "workspace:^",
    "@observablehq/plot": "^0.6.17",
    "@solidjs/web": "2.0.0-beta.15",
    "@uwdata/mosaic-plot": "^0.28.1",
    "katex": "^0.17.0",
    "solid-js": "2.0.0-beta.15",
    "vite": "^6.4.1",
    "vite-plugin-solid": "3.0.0-next.5"
  }
}
