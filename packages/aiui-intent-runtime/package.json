{
  "name": "@habemus-papadum/aiui-intent-runtime",
  "version": "0.11.0+dev",
  "description": "The intent client's host-agnostic capture + transport runtime: mic/screen capture, the frame sampler, the selection watcher, and the channel wire.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/habemus-papadum/pdum_aiui.git",
    "directory": "packages/aiui-intent-runtime"
  },
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./locator": "./src/locator.ts",
    "./talk": "./src/talk.ts",
    "./video": "./src/video.ts",
    "./selection": "./src/selection.ts",
    "./instrumentation": "./src/instrumentation.ts",
    "./wire": "./src/wire.ts",
    "./thread": "./src/thread.ts"
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./locator": {
        "types": "./dist/locator.d.ts",
        "import": "./dist/locator.js",
        "default": "./dist/locator.js"
      },
      "./talk": {
        "types": "./dist/talk.d.ts",
        "import": "./dist/talk.js",
        "default": "./dist/talk.js"
      },
      "./video": {
        "types": "./dist/video.d.ts",
        "import": "./dist/video.js",
        "default": "./dist/video.js"
      },
      "./selection": {
        "types": "./dist/selection.d.ts",
        "import": "./dist/selection.js",
        "default": "./dist/selection.js"
      },
      "./instrumentation": {
        "types": "./dist/instrumentation.d.ts",
        "import": "./dist/instrumentation.js",
        "default": "./dist/instrumentation.js"
      },
      "./wire": {
        "types": "./dist/wire.d.ts",
        "import": "./dist/wire.js",
        "default": "./dist/wire.js"
      },
      "./thread": {
        "types": "./dist/thread.d.ts",
        "import": "./dist/thread.js",
        "default": "./dist/thread.js"
      }
    }
  },
  "scripts": {
    "build": "tsc --emitDeclarationOnly -p tsconfig.json && vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@habemus-papadum/aiui-lowering-pipeline": "workspace:^"
  },
  "devDependencies": {
    "@habemus-papadum/aiui-build-config": "workspace:^",
    "@habemus-papadum/aiui-claude-channel": "workspace:^",
    "jsdom": "^29.0.0",
    "vite": "^6.4.1"
  }
}
