{
  "name": "@habemus-papadum/aiui-remote-bar",
  "version": "0.9.0",
  "description": "The command bar as its own channel: a mode engine projected over a websocket, mounted as a channel sidecar, with a Solid client that renders the bar and dispatches taps.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/habemus-papadum/pdum_aiui.git",
    "directory": "packages/aiui-remote-bar"
  },
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/backend.ts",
    "./sidecar": "./src/sidecar.ts"
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./server": {
        "types": "./dist/backend.d.ts",
        "import": "./dist/backend.js",
        "default": "./dist/backend.js"
      },
      "./sidecar": {
        "types": "./dist/sidecar.d.ts",
        "import": "./dist/sidecar.js",
        "default": "./dist/sidecar.js"
      }
    }
  },
  "scripts": {
    "build": "tsc --emitDeclarationOnly -p tsconfig.json && tsc --emitDeclarationOnly -p tsconfig.node.json && vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@habemus-papadum/aiui-room-relay": "workspace:^",
    "@habemus-papadum/aiui-viz": "workspace:^",
    "@solidjs/web": "2.0.0-beta.15",
    "solid-js": "2.0.0-beta.15"
  },
  "devDependencies": {
    "@habemus-papadum/aiui-build-config": "workspace:^",
    "@habemus-papadum/aiui-claude-channel": "workspace:^",
    "@types/express": "^5.0.0",
    "@types/ws": "^8.5.0",
    "express": "^5.1.0",
    "jsdom": "^29.0.0",
    "vite": "^6.4.1",
    "vite-plugin-solid": "3.0.0-next.5",
    "ws": "^8.18.0"
  },
  "peerDependencies": {
    "@habemus-papadum/aiui-claude-channel": "workspace:^",
    "express": "^5.1.0"
  },
  "peerDependenciesMeta": {
    "@habemus-papadum/aiui-claude-channel": {
      "optional": true
    },
    "express": {
      "optional": true
    }
  }
}
