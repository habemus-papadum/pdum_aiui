{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "declarationDir": "dist",
    // This package ships no JSX, but it imports the aiui-viz barrel SOURCE
    // (the workspace editable-deps convention), which reaches .tsx modules.
    "jsx": "preserve",
    "jsxImportSource": "@solidjs/web"
  },
  "include": ["src"],
  "exclude": ["dist", "node_modules", "src/**/*.test.ts"]
}
