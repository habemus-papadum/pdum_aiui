{
  "name": "@habemus-papadum/aiui-console",
  "version": "0.11.2",
  "description": "The aiui channel console: a dashboard landing page and the trace debugger, served at the channel root.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/habemus-papadum/pdum_aiui.git",
    "directory": "packages/aiui-console"
  },
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./sidecar": "./src/sidecar.ts"
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "dist",
    "src",
    "assets"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./sidecar": {
        "types": "./dist/sidecar.d.ts",
        "import": "./dist/sidecar.js",
        "default": "./dist/sidecar.js"
      }
    }
  },
  "scripts": {
    "build": "tsc --emitDeclarationOnly -p tsconfig.json && vite build && pnpm build:app",
    "build:app": "vite build --config app/vite.config.ts",
    "dev:app": "vite app",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p app/tsconfig.json && tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run"
  },
  "peerDependencies": {
    "vite": ">=6"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "dependencies": {
    "@habemus-papadum/aiui-trace-ui": "workspace:^",
    "@habemus-papadum/aiui-util": "workspace:^",
    "@solidjs/web": "2.0.0-beta.15",
    "solid-js": "2.0.0-beta.15"
  },
  "devDependencies": {
    "@habemus-papadum/aiui-build-config": "workspace:^",
    "@habemus-papadum/aiui-claude-channel": "workspace:^",
    "@types/express": "^5.0.0",
    "express": "^5.1.0",
    "jsdom": "^29.0.0",
    "vite": "^6.4.1",
    "vite-plugin-solid": "3.0.0-next.5"
  }
}
