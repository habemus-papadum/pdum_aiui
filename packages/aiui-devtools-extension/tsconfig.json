{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // Emit real JS the extension pages load directly (no bundler): NodeNext
    // modules keep the explicit ./x.js import specifiers browsers need.
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "extension/js",
    "declaration": false,
    "emitDeclarationOnly": false,
    // This package emits real JS via tsc (NodeNext, `./x.js` specifiers), which
    // is incompatible with the base's `allowImportingTsExtensions`; turn the
    // `.ts`-import flags off here.
    "allowImportingTsExtensions": false,
    "rewriteRelativeImportExtensions": false,
    "types": ["chrome"]
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts"]
}
