{
  "name": "@habemus-papadum/aiui",
  "version": "0.2.0+dev",
  "description": "ai ui frontends",
  "type": "module",
  "license": "MIT",
  "author": "Nehal Patel <nehal@alum.mit.edu>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/habemus-papadum/pdum_aiui.git",
    "directory": "packages/aiui"
  },
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts"
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "aiui": "./dist/cli.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsc --emitDeclarationOnly -p tsconfig.json && vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@habemus-papadum/aiui-claude-channel": "workspace:^",
    "@habemus-papadum/aiui-claude-plugin": "workspace:^",
    "@habemus-papadum/aiui-devtools-extension": "workspace:^",
    "@habemus-papadum/aiui-util": "workspace:^",
    "@puppeteer/browsers": "^2.10.5",
    "chalk": "^5.3.0",
    "commander": "^15.0.0",
    "execa": "^9.6.1",
    "vite": "^6.4.3"
  }
}
