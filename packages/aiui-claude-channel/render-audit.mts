// ‚îÄ‚îÄ write, backing up the previous round so annotations survive and diff ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

const content = out.join("\n");
if (DOCS_MODE) {
  const repoRoot = join(dirname(fileURLToPath(import.meta.url)), "..", "..");
  const target = join(repoRoot, "docs", "guide", "prompt-rendering.md");
  writeFileSync(target, content);
  console.log(`wrote ${target} (${caseNo} cases, docs mode)`);
} else if (process.argv[2] !== undefined) {
  // Preview mode: a single copy at an explicit path, no backups.
  writeFileSync(process.argv[2], content);
  console.log(`wrote ${process.argv[2]} (${caseNo} cases)`);
} else {
  const repoRoot = join(dirname(fileURLToPath(import.meta.url)), "..", "..");
  const auditDir = join(repoRoot, "audit.local");
  mkdirSync(auditDir, { recursive: true });
  const pristine = join(auditDir, "render-audit.md");
  const markup = join(auditDir, "render-audit.markup.md");
  // Back the previous round up as a numbered PAIR, so any round diffs cleanly
  // against any other (and annotations survive regeneration).
  if (existsSync(pristine) || existsSync(markup)) {
    const versions = readdirSync(auditDir)
      .map((f) => /^render-audit(?:\.markup)?\.v(\d+)\.md$/.exec(f)?.[1])
      .filter((v): v is string => v !== undefined)
      .map(Number);
    const next = versions.length > 0 ? Math.max(...versions) + 1 : 1;
    if (existsSync(pristine)) {
      copyFileSync(pristine, join(auditDir, `render-audit.v${next}.md`));
    }
    if (existsSync(markup)) {
      copyFileSync(markup, join(auditDir, `render-audit.markup.v${next}.md`));
    }
    console.log(`backed up previous round as v${next}`);
  }
  writeFileSync(pristine, content);
  writeFileSync(markup, content);
  console.log(`wrote ${pristine} + .markup twin (${caseNo} cases)`);
}
