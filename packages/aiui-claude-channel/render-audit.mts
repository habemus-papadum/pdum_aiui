/** A static-text case (not executed ‚Äî quoted from source, with its location). */
function quote(title: string, note: string, body: string): void {
  caseNo += 1;
  md(`### ${caseNo}. ${title}\n`);
  if (note) md(`${note}\n`);
  md("````text\n" + body + "\n````\n");
  comments();
}

