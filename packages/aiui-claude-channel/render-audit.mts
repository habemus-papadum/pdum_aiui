/**
 * Render-audit harness (uncommitted working tool).
 *
 * Drives every item→text render path in the lowering pipeline's render.ts, plus
 * the channel's context preamble and the MCP self-description strings, with
 * representative inputs, and emits the ACTUAL rendered output for each case as
 * one markdown document — so the audit reviews real outputs side by side
 * instead of spelunking the code.
 *
 * The annotate-iterate loop:
 *  - output goes to <repo>/audit.local/render-audit.md (gitignored via *.local)
 *  - every case ends with a `**Comments:**` block; the owner writes decisions
 *    there in place, and the agent reads them back to drive code changes
 *  - each run first backs up the existing file to render-audit.v<N>.md, so an
 *    annotated round survives regeneration and `diff v<N> render-audit.md`
 *    shows exactly what a code change did to the outputs
 *
 * Run: pnpm exec tsx render-audit.mts [output.md]   (from this package dir)
 */
import { copyFileSync, existsSync, mkdirSync, readdirSync, writeFileSync } from "node:fs";
import { dirname, join } from "node:path";
import { fileURLToPath } from "node:url";
import {
  type ComposedItem,
  type ComposeOptions,
  renderPrompt,
} from "@habemus-papadum/aiui-lowering-pipeline";
import {
  promptContextSections,
  selectionSections,
  wrapWithContextParts,
} from "./src/prompt-context";

const CWD = "/repo/app";
const out: string[] = [];
const md = (s: string): void => {
  out.push(s);
};

const NO_COMMENT = "_none yet_";
/** The owner's annotation slot — one per case, edited in place in the output. */
const comments = (): void => {
  md(`**Comments:**\n\n${NO_COMMENT}\n`);
};

let caseNo = 0;
/** Render `items` through the real pass 5 and emit the case as markdown. */
function show(
  title: string,
  note: string,
  items: ComposedItem[],
  options: ComposeOptions = { cwd: CWD },
): void {
  caseNo += 1;
  const composed = renderPrompt(items, [], "replace", options);
  md(`### ${caseNo}. ${title}\n`);
  if (note) md(`${note}\n`);
  md("````text\n" + composed.prompt + "\n````\n");
  comments();
}

