/**
 * `--docs` mode: emit the settled reference (no Comments blocks, a
 * documentation intro) to docs/guide/prompt-rendering.md instead of the
 * audit.local working pair.
 */
const DOCS_MODE = process.argv.includes("--docs");

const CWD = "/repo/app";
const out: string[] = [];
const md = (s: string): void => {
  out.push(s);
};

const NO_COMMENT = "_none yet_";
/** The owner's annotation slot ‚Äî one per case; absent from the docs build. */
const comments = (): void => {
  if (!DOCS_MODE) {
    md(`**Comments:**\n\n${NO_COMMENT}\n`);
  }
};

let caseNo = 0;

/** Drop fields the renderer never reads from the Input displays (noted in the intro). */
const jsonReplacer = (key: string, value: unknown): unknown =>
  key === "rect" || key === "segment" ? undefined : value;

/** Render `items` through the real pass 5 and emit the case as Input ‚Üí Rendered. */
function show(
  title: string,
  note: string,
  items: ComposedItem[],
  options: ComposeOptions = { cwd: CWD },
): void {
  caseNo += 1;
  const composed = renderPrompt(items, [], "replace", options);
  md(`### ${caseNo}. ${title}\n`);
  if (note) md(`${note}\n`);
  const value = items.length === 1 ? items[0] : items;
  md("Input:\n");
  md("````json\n" + JSON.stringify(value, jsonReplacer, 2) + "\n````\n");
  md("Rendered:\n");
  md("````text\n" + composed.prompt + "\n````\n");
  comments();
}

