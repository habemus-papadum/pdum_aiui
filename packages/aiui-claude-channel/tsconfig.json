{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "declarationDir": "dist",
    // jsx is never emitted here (node package) — set only so tsc can follow
    // source-first imports through intent-client's sidecar into aiui-viz's .tsx.
    "jsx": "preserve",
    "jsxImportSource": "@solidjs/web",
    "types": ["node"]
  },
  "include": ["src"],
  // fake-upstream.ts is a test-only fixture (not a *.test.ts file); keep it out of
  // the declaration build since no production module imports it.
  "exclude": ["dist", "node_modules", "src/**/*.test.ts", "src/fake-upstream.ts"]
}
