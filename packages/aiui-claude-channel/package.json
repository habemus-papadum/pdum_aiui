{
  "name": "@habemus-papadum/aiui-claude-channel",
  "version": "0.1.0+dev",
  "description": "MCP server providing a custom Claude channel, plus a CLI to launch it and print config.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/habemus-papadum/pdum_aiui.git",
    "directory": "packages/aiui-claude-channel"
  },
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts"
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "aiui-claude-channel": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsc --emitDeclarationOnly -p tsconfig.json && vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@habemus-papadum/aiui-util": "workspace:^",
    "@inquirer/prompts": "^7.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^15.0.0",
    "express": "^5.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/ws": "^8.5.0"
  }
}
