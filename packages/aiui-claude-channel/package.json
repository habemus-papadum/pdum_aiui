{
  "name": "@habemus-papadum/aiui-claude-channel",
  "version": "0.0.0+dev",
  "description": "MCP server providing a custom Claude channel, plus a CLI to launch it and print config.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/habemus-papadum/pdum_aiui.git",
    "directory": "packages/aiui-claude-channel"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "aiui-claude-channel": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "restricted"
  },
  "scripts": {
    "build": "tsc --emitDeclarationOnly -p tsconfig.json && vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@habemus-papadum/aiui-util": "workspace:^",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^15.0.0"
  }
}
