#!/usr/bin/env bash
# aiui LSP launcher — typescript (typescript-language-server). Generated by `aiui setup-lsp`.
# Speaks LSP on stdio; the channel/reader spawns this and pipes bytes.
# ROOT is this project (the launcher lives at .aiui/lsp/<lang>/launch, three
# levels down); the server is the nearest node_modules/.bin install at or
# above ROOT (a workspace member finds its monorepo root's), node from PATH.
ROOT="$(cd "$(dirname "$0")/../../.." && pwd)"
DIR="$ROOT"
while true; do
  BIN="$DIR/node_modules/.bin/typescript-language-server"
  [ -x "$BIN" ] && exec "$BIN" --stdio "$@"
  [ "$DIR" = "/" ] && break
  DIR="$(dirname "$DIR")"
done
echo "aiui LSP launcher: typescript-language-server not found in node_modules/.bin at or above $ROOT — pnpm add -D typescript-language-server typescript" >&2
exit 127
