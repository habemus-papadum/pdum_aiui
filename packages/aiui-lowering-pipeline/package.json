{
  "name": "@habemus-papadum/aiui-lowering-pipeline",
  "version": "0.8.0+dev",
  "description": "The intent lowering pipeline: the framework-free core that folds a multimodal intent event stream into the lowered agent prompt (composeIntent), shared by the channel and the intent tools.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/habemus-papadum/pdum_aiui.git",
    "directory": "packages/aiui-lowering-pipeline"
  },
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./trace-stages": "./src/trace-stages.ts"
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "./trace-stages": {
        "types": "./dist/trace-stages.d.ts",
        "import": "./dist/trace-stages.js",
        "default": "./dist/trace-stages.js"
      }
    }
  },
  "scripts": {
    "build": "tsc --emitDeclarationOnly -p tsconfig.json && vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@habemus-papadum/aiui-viz": "workspace:^"
  },
  "devDependencies": {
    "@habemus-papadum/aiui-build-config": "workspace:^"
  }
}
