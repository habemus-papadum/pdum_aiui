{
  "name": "@habemus-papadum/create-aiui",
  "version": "0.9.0",
  "description": "Scaffold a SolidJS + aiui starter app: pnpm create @habemus-papadum/aiui",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/habemus-papadum/pdum_aiui.git",
    "directory": "packages/create-aiui"
  },
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts"
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "create-aiui": "./dist/cli.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsc --emitDeclarationOnly -p tsconfig.json && vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.template.json",
    "test": "vitest run"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@habemus-papadum/aiui-build-config": "workspace:^",
    "@habemus-papadum/aiui-source-processor": "workspace:^",
    "@habemus-papadum/aiui-viz": "workspace:^",
    "@solidjs/web": "2.0.0-beta.15",
    "solid-js": "2.0.0-beta.15",
    "typescript": "^5.6.0",
    "vite": "^6.4.1",
    "vite-plugin-solid": "3.0.0-next.5",
    "vitest": "^3.2.0"
  }
}
