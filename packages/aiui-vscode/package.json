{
  "name": "@habemus-papadum/aiui-vscode",
  "version": "0.11.1",
  "description": "VS Code extension: a selection provider for aiui sessions — pick a connected browser tab and send editor selections to it.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/habemus-papadum/pdum_aiui.git",
    "directory": "packages/aiui-vscode"
  },
  "homepage": "https://github.com/habemus-papadum/pdum_aiui/tree/main/packages/aiui-vscode#readme",
  "bugs": {
    "url": "https://github.com/habemus-papadum/pdum_aiui/issues"
  },
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts"
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      }
    }
  },
  "displayName": "aiui",
  "publisher": "habemus-papadum",
  "icon": "media/icon.png",
  "categories": [
    "Other"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "aiui.pickBrowserTab",
        "category": "aiui",
        "title": "Pick Browser Tab"
      },
      {
        "command": "aiui.sendSelection",
        "category": "aiui",
        "title": "Send Selection to Browser Tab"
      },
      {
        "command": "aiui.refreshTabs",
        "category": "aiui",
        "title": "Refresh Browser Tabs"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "aiui.sendSelection",
          "when": "editorHasSelection",
          "group": "9_aiui"
        }
      ]
    }
  },
  "scripts": {
    "build": "tsc --emitDeclarationOnly -p tsconfig.json && vite build && node build-extension.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "vsix": "node build-extension.mjs --vsix",
    "install:vsix": "node build-extension.mjs --vsix --install",
    "install:dir": "node build-extension.mjs --link"
  },
  "dependencies": {
    "@habemus-papadum/aiui-registry": "catalog:",
    "@habemus-papadum/aiui-util": "workspace:^"
  },
  "devDependencies": {
    "@habemus-papadum/aiui-build-config": "workspace:^",
    "@habemus-papadum/aiui-claude-channel": "workspace:^",
    "@types/node": "^26.1.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.25.0"
  }
}
