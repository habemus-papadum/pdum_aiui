{
  "name": "pdum_aiui",
  "version": "0.8.0",
  "private": true,
  "type": "module",
  "description": "pdum_aiui - a lockstep-versioned TypeScript monorepo.",
  "author": "Nehal Patel <nehal@alum.mit.edu>",
  "license": "MIT",
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  },
  "scripts": {
    "prepare": "git config core.hooksPath .githooks",
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:packaging": "node scripts/packaging-test.mjs",
    "test:template": "tsx scripts/template-e2e.ts",
    "lint": "biome check .",
    "docs:lint": "node scripts/docs-lint.mjs",
    "format": "biome check --write .",
    "aiui": "tsx packages/aiui/src/cli.ts",
    "vscode:vsix": "pnpm --filter @habemus-papadum/aiui-vscode install:vsix",
    "vscode:install": "pnpm --filter @habemus-papadum/aiui-vscode install:vsix",
    "vscode:link": "pnpm --filter @habemus-papadum/aiui-vscode install:dir",
    "new-package": "node scripts/new-package.mjs",
    "new-demo": "tsx scripts/new-demo.ts",
    "skills:check": "node scripts/bundle-skill-docs.mjs --check",
    "npm:list": "node scripts/npm-provision.mjs list",
    "npm:reserve": "node scripts/npm-provision.mjs reserve",
    "npm:trust": "node scripts/npm-provision.mjs trust",
    "version:check": "node scripts/versioning.mjs current",
    "docs:gen": "node scripts/docs-gen.mjs",
    "docs:dev": "pnpm docs:gen && vitepress dev docs",
    "docs:build": "pnpm docs:gen && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "demo": "pnpm -C demos/gallery dev",
    "test-app": "pnpm -C packages/aiui-test-app dev",
    "test-app:channel": "tsx packages/aiui/src/cli.ts mcp serve --name \"aiui test app\" --tag aiui-test-app --port 49317"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@types/node": "^26.1.0",
    "mermaid": "^11.16.0",
    "tsx": "^4.22.5",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "typedoc-vitepress-theme": "^1.1.3",
    "typescript": "^5.6.0",
    "typescript-language-server": "^5.3.0",
    "vite": "^6.0.0",
    "vitepress": "^1.6.4",
    "vitepress-plugin-mermaid": "^2.0.17",
    "vitest": "^3.2.0"
  },
  "packageManager": "pnpm@11.9.0"
}
