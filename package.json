{
  "name": "pdum_aiui",
  "version": "0.0.0+dev",
  "private": true,
  "type": "module",
  "description": "pdum_aiui \u2014 a lockstep-versioned TypeScript monorepo.",
  "author": "Nehal Patel <nehal@alum.mit.edu>",
  "license": "MIT",
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:packaging": "node scripts/packaging-test.mjs",
    "lint": "biome check .",
    "format": "biome check --write .",
    "aiui": "tsx packages/aiui/src/cli.ts",
    "new-package": "node scripts/new-package.mjs",
    "npm:list": "node scripts/npm-provision.mjs list",
    "npm:reserve": "node scripts/npm-provision.mjs reserve",
    "npm:trust": "node scripts/npm-provision.mjs trust",
    "version:check": "node scripts/versioning.mjs current",
    "docs:gen": "node scripts/docs-gen.mjs",
    "docs:dev": "pnpm docs:gen && vitepress dev docs",
    "docs:build": "pnpm docs:gen && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "demo": "tsx packages/aiui/src/cli.ts vite packages/aiui-demo"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/node": "^26.1.0",
    "tsx": "^4.22.5",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "typedoc-vitepress-theme": "^1.1.3",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitepress": "^1.6.4",
    "vitest": "^3.2.0"
  },
  "packageManager": "pnpm@11.9.0"
}
