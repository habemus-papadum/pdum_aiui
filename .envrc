# direnv (https://direnv.net) — the auto-loading twin of `eval "$(./aiui env)"`:
# cd into the repo and the shell is activated; cd out and it's undone. This is
# the standard per-directory activation for zsh/bash (pnpm has no native one).
#
# One-time setup:
#   brew install direnv                     # or your package manager
#   eval "$(direnv hook zsh)"               # in ~/.zshrc
#   direnv allow                            # in this repo, after reading this file
#
# `layout node` is direnv's stdlib helper: it prepends ./node_modules/.bin.
layout node
PATH_add bin
dotenv_if_exists .env
dotenv_if_exists .env.dev
