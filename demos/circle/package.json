{
  "name": "@habemus-papadum/demo-circle",
  "version": "0.12.0+dev",
  "description": "How round can you draw a circle? A vanishing-ink pencil surface, a live least-squares fit, and a Zen centre-ghost \u2014 the pencil-package demo.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/habemus-papadum/pdum_aiui.git",
    "directory": "demos/circle"
  },
  "exports": {
    ".": "./src/index.ts",
    "./page": "./src/page.tsx",
    "./card": "./src/card.tsx"
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "aiui": {
    "sitePage": {
      "title": "circle",
      "desc": "how round can you draw a circle?",
      "order": 40,
      "card": "./card"
    }
  },
  "scripts": {
    "claude": "../../bin/aiui claude",
