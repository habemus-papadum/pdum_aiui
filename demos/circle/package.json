    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@habemus-papadum/aiui-journal": "workspace:^",
    "@habemus-papadum/aiui-pencil": "workspace:^",
    "@habemus-papadum/aiui-source-processor": "workspace:^",
    "@habemus-papadum/aiui-viz": "workspace:^",
    "@solidjs/web": "2.0.0-beta.15",
    "katex": "^0.17.0",
    "solid-js": "2.0.0-beta.15"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@habemus-papadum/aiui": "workspace:^",
    "jsdom": "^29.0.0",
    "typescript": "^5.6.0",
    "typescript-language-server": "^5.3.0",
    "vite": "^6.4.1",
    "vite-plugin-solid": "3.0.0-next.5",
    "vitest": "^3.2.0"
