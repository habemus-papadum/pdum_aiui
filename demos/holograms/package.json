{
  "name": "@habemus-papadum/demo-holograms",
  "version": "0.12.0+dev",
  "description": "The film that remembers light: record interference on a virtual bench, develop the film, replay the reference, and the object's wavefront comes back \u2014 parallax, cut-the-film, magnification remixes, and every real failure mode, computed live from the wave equation.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/habemus-papadum/pdum_aiui.git",
    "directory": "demos/holograms"
  },
  "exports": {
    ".": "./src/index.ts",
    "./page": "./src/page.tsx",
    "./card": "./src/card.tsx"
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "aiui": {
    "sitePage": {
      "title": "holograms",
      "desc": "the film that remembers light",
      "order": 70,
      "card": "./card"
    }
  },
  "scripts": {
    "claude": "../../bin/aiui claude",
    "dev": "vite",
    "open": "../../bin/aiui open",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@habemus-papadum/aiui-journal": "workspace:^",
    "@habemus-papadum/aiui-optics": "workspace:^",
    "@habemus-papadum/aiui-source-processor": "workspace:^",
    "@habemus-papadum/aiui-viz": "workspace:^",
    "@solidjs/web": "2.0.0-beta.15",
    "solid-js": "2.0.0-beta.15"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@habemus-papadum/aiui": "workspace:^",
    "jsdom": "^29.0.0",
    "typescript": "^5.6.0",
    "typescript-language-server": "^5.3.0",
    "vite": "^6.4.1",
    "vite-plugin-solid": "3.0.0-next.5",
    "vitest": "^3.2.0"
  }
}
